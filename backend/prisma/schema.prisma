// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==============================================
// ENUMS
// ==============================================

enum UserRole {
  Developer
  Manager
  HRofficer
  Admin
  ResearchAdmin
}

enum WorkModel {
  Remote
  Hybrid
  Onsite
}

enum RiskLevel {
  Low
  Moderate
  High
  Critical
}

enum TrendDirection {
  Improving
  Stable
  Worsening
}

enum ShapDirection {
  IncreasesRisk
  DecreasesRisk
}

enum RecommendationCategory {
  Sleep
  Exercise
  WorkBoundary
  Social
  ScreenTime
  Workload
}

enum AlertType {
  Email
  Push
  InApp
}

enum AlertSeverity {
  Info
  Warning
  Critical
}

// ==============================================
// MODELS
// ==============================================

model User {
  userId          String    @id @default(uuid())
  email           String    @unique
  passwordHash    String?
  fullName        String
  role            UserRole
  company         String?
  isActive        Boolean   @default(true)
  isEmailVerified Boolean   @default(false)
  lastLoginAt     DateTime?
  googleId        String?   @unique
  emailNotificationsEnabled Boolean @default(true)

  // Relations
  developerProfile   DeveloperProfile?
  dailyCheckIns      DailyCheckIn[]
  burnoutPredictions BurnoutPrediction[]
  recommendations    Recommendation[]
  chatMessages       ChatMessage[]
  wellnessReports    WellnessReport[]
  alerts             Alert[]

  // Audit Fields
  createdBy       String
  createdDateTime DateTime  @default(now())
  modifiedBy      String
  modifiedDate    DateTime  @updatedAt
}

model DeveloperProfile {
  profileId         String    @id @default(uuid())
  userId            String    @unique
  jobTitle          String?
  yearsExperience   Int?
  workModel         WorkModel @default(Onsite)
  teamSize          Int?
  avgDailyHours     Float?
  baselineRiskScore Float?
  totalCheckIns     Int       @default(0)
  currentStreak     Int       @default(0)

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  // Audit Fields
  createdBy       String
  createdDateTime DateTime  @default(now())
  modifiedBy      String
  modifiedDate    DateTime  @updatedAt
}

model DailyCheckIn {
  checkInId           String    @id @default(uuid())
  userId              String
  checkInDate         DateTime
  
  // Sleep & Rest
  sleepHours          Float
  sleepQuality        Int
  
  // Physical Activity
  exerciseLevel       Int       // 1-5 scale (None to Intense)
  screenTimeHours     Float
  
  // Work & Productivity
  workHours           Float
  workloadRating      Int
  overtimeHours       Float     // Additional hours beyond normal
  breaksTaken         Int       // Number of breaks taken
  commuteMinutes      Int       // Commute duration in minutes
  
  // Work Pattern Monitoring
  meetingsCount             Int      @default(0)   // Number of meetings today (0-20)
  urgentTasksCount          Int      @default(0)   // Number of urgent/unplanned tasks today (0-20)
  sprintPressureRating      Int      @default(3)   // 1-5 scale
  deadlineFrequency         Int      @default(3)   // 1-5 scale — how often deadlines occur this week
  isWeekendWork             Boolean  @default(false)
  bugFixingLoad             Int      @default(3)   // 1-5 scale
  contextSwitchingFrequency Int      @default(3)   // 1-5 scale
  isOnCallToday             Boolean  @default(false)

  // Mental & Emotional
  stressLevel         Int
  moodScore           Int
  energyLevel         Int
  workSatisfaction    Int       // 1-5 scale
  
  // Lifestyle & Health
  caffeineIntake      Int       // mg or cups (0-10 scale)
  mealQuality         Int       // 1-5 scale
  socialSupportLevel  Int       // 1-5 scale
  
  // Psychological Wellbeing
  anxietyLevel        Int       // 1-10 scale
  emotionalFatigue    Int       // 1-10 scale
  motivationLevel     Int       // 1-5 scale
  concentrationIssues Int       // 1-5 scale
  irritabilityLevel   Int       // 1-5 scale
  lonelinessLevel     Int       // 1-5 scale
  selfEfficacy        Int       // 1-5 scale
  copingAbility       Int       // 1-5 scale
  
  // Work Context (Sri Lankan & Global)
  powerInternetDisruption Int  // 1-5 scale (WFH disruption stress, SL-specific)
  wfhEnvironmentQuality Int    // 1-5 scale
  familyResponsibilityLoad Int // 1-5 scale
  salaryWorkloadSatisfaction Int // 1-5 scale
  afterHoursMessaging Boolean  // Work communication outside hours
  
  // Meta
  notes               String?
  isEdited            Boolean   @default(false)
  editedAt            DateTime?

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  // Audit Fields
  createdBy           String
  createdDateTime     DateTime  @default(now())
  modifiedBy          String
  modifiedDate        DateTime  @updatedAt
}

model BurnoutPrediction {
  predictionId      String         @id @default(uuid())
  userId            String
  riskScore         Float
  riskLevel         RiskLevel
  modelVersion      String
  checkInsUsed      Int
  predictionDate    DateTime
  isLatest          Boolean        @default(true)
  trendDirection    TrendDirection @default(Stable)
  previousRiskScore Float?
  scoreChange       Float?

  // Relations
  user             User              @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  shapExplanations ShapExplanation[]
  recommendations  Recommendation[]
  alerts           Alert[]
  chatMessages     ChatMessage[]

  // Audit Fields
  createdBy       String
  createdDateTime DateTime  @default(now())
  modifiedBy      String
  modifiedDate    DateTime  @updatedAt
}

model ShapExplanation {
  shapId            String        @id @default(uuid())
  predictionId      String
  featureName       String
  shapValue         Float
  featureValue      Float
  importanceRank    Int
  direction         ShapDirection
  plainLanguageText String?

  // Relations
  prediction BurnoutPrediction @relation(fields: [predictionId], references: [predictionId], onDelete: Cascade)

  // Audit Fields
  createdBy       String
  createdDateTime DateTime  @default(now())
  modifiedBy      String
  modifiedDate    DateTime  @updatedAt
}

model Recommendation {
  recId              String                 @id @default(uuid())
  predictionId       String
  userId             String
  category           RecommendationCategory
  title              String
  description        String
  priority           Int
  isCompleted        Boolean                @default(false)
  completedAt        DateTime?
  isDismissed        Boolean                @default(false)
  dismissedAt        DateTime?
  effectivenessScore Float?

  // Relations
  user       User              @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  prediction BurnoutPrediction @relation(fields: [predictionId], references: [predictionId], onDelete: NoAction, onUpdate: NoAction)

  // Audit Fields
  createdBy       String
  createdDateTime DateTime  @default(now())
  modifiedBy      String
  modifiedDate    DateTime  @updatedAt
}

model ChatMessage {
  chatId              String               @id @default(uuid())
  userId              String
  role                String
  content             String               @db.Text
  relatedPredictionId  String?

  // Relations
  user                User                 @relation(fields: [userId], references: [userId], onDelete: Cascade)
  relatedPrediction   BurnoutPrediction?    @relation(fields: [relatedPredictionId], references: [predictionId], onDelete: SetNull)

  // Audit Fields
  createdBy           String
  createdDateTime     DateTime  @default(now())
  modifiedBy          String
  modifiedDate        DateTime  @updatedAt
}

model WellnessReport {
  reportId             String         @id @default(uuid())
  userId               String
  weekStart            DateTime
  weekEnd              DateTime
  avgStress            Float
  avgSleep             Float
  avgMood              Float
  avgWorkHours         Float
  totalCheckIns        Int
  exerciseDays         Int
  overallTrend         TrendDirection
  riskScoreAtEndOfWeek Float?
  insightSummary       String?

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  // Audit Fields
  createdBy       String
  createdDateTime DateTime  @default(now())
  modifiedBy      String
  modifiedDate    DateTime  @updatedAt
}

model Alert {
  alertId      String        @id @default(uuid())
  userId       String
  predictionId String?
  alertType    AlertType
  severity     AlertSeverity
  message      String
  isRead       Boolean       @default(false)
  readAt       DateTime?
  isDismissed  Boolean       @default(false)
  sentAt       DateTime

  // Relations
  user       User               @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  prediction BurnoutPrediction? @relation(fields: [predictionId], references: [predictionId], onDelete: NoAction, onUpdate: NoAction)

  // Audit Fields
  createdBy       String
  createdDateTime DateTime  @default(now())
  modifiedBy      String
  modifiedDate    DateTime  @updatedAt
}

model AuditLog {
  logId           String   @id @default(uuid())
  actorId         String?
  actorEmail      String
  actorRole       String
  action          String
  entityType      String
  entityId        String?
  ipAddress       String?
  result          String   @default("Success")
  details         String?  @db.Text
  createdDateTime DateTime @default(now())
}
